# Copy to .env.production locally before running `npm run build` for prod.
# NEXT_PUBLIC_* values are inlined at build time, not read at runtime —
# they MUST be set during the local build, not on the EC2 box.

NEXT_PUBLIC_API_URL=https://api.cpc24.co.in
# Public base URL of the S3 bucket (products/ prefix is public-read). Used to
# render existing image thumbnails in the admin editor.
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=https://cpn-uploads.s3.ap-south-1.amazonaws.com
# Public business identifiers shown in the site footer. Assam GSTIN starts with 18.
# Leave blank to hide a line.
NEXT_PUBLIC_SELLER_GSTIN=18XXXXXXXXXXXZX
NEXT_PUBLIC_SELLER_IEC=XXXXXXXXXX
